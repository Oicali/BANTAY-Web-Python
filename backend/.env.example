# Edit the .env file to include the following line
# Database (from Aiven dashboard)
# use these in db.js for connecting to PostgreSQL (update with your actual Aiven credentials and CA cert path)
DB_USER=
DB_PASS=
DB_HOST=
DB_PORT=
DB_NAME=
DB_SSL_CA=

# Cloudinary (for image uploads) 
# used in profileController.js for uploading profile pictures and in userController.js for constructing image URLs (update with your actual Cloudinary credentials)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

DB_IMG = 

JWT_SECRET=


BREVO_API_KEY=
BREVO_SENDER_EMAIL=


NODE_ENV=development # set to 'production' in production for things like logging and error handling
PORT=5000 # use in server.js for backend server port

BACKEND_URL=http://localhost:5000 # use in userController.js for constructing verification email links (update to actual URL in production)
FRONTEND_URL=http://localhost:5173 # for CORS and email links in emailService.js

# =========================
# AI ASSESSMENT / PYTHON
# =========================
PYTHON_SERVICE_URL=http://localhost:8000
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
GEMINI_API_KEY=